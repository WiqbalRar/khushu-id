<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.sniper1720.khushu</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>
  <name>Khushu</name>
  <summary>An all-in-one Muslim app for Linux.</summary>
  <description>
    <p>
      Khushu is your all-in-one Muslim app for Linux desktop, tablets, and smartphones.
      It centralizes your daily worship by providing accurate prayer times, native staggered 
      Adkar notifications, and a roadmap that includes a dedicated Holy Quran experience—all 
      with uncompromising privacy and zero telemetry.
    </p>
    <ul>
      <li>Accurate prayer calculation methods (Offline)</li>
      <li>Morning, Evening, and Night Adkar with built-in counters</li>
      <li>Customizable Adhan system notifications (Makkah/Madinah audio)</li>
      <li>Interactive Qibla compass</li>
      <li>Hijri calendar mapping</li>
      <li>Privacy-first local encryption for your location data</li>
      <li>Modern Libadwaita interface with adaptive Dark Mode</li>
      <li>Multi-language support</li>
    </ul>
  </description>
  <launchable type="desktop-id">io.github.sniper1720.khushu.desktop</launchable>
  <screenshots>
    <screenshot type="default">
      <caption>Prayer Times Dashboard: View accurate daily Salah times, upcoming prayer countdown, and Hijri date.</caption>
      <image>https://raw.githubusercontent.com/sniper1720/khushu/main/screenshots/prayer-times.png</image>
    </screenshot>
    <screenshot>
      <caption>Adkar &amp; Supplications: Access Daily Adkar with built-in counters and staggered notifications.</caption>
      <image>https://raw.githubusercontent.com/sniper1720/khushu/main/screenshots/adkar.png</image>
    </screenshot>
    <screenshot>
      <caption>Interactive Qibla Direction: A beautifully rendered compass pointing to Mecca based on your GPS.</caption>
      <image>https://raw.githubusercontent.com/sniper1720/khushu/main/screenshots/qibla.png</image>
    </screenshot>
  </screenshots>
  <url type="homepage">https://github.com/sniper1720/khushu</url>
  <url type="bugtracker">https://github.com/sniper1720/khushu/issues</url>
  <url type="vcs-browser">https://github.com/sniper1720/khushu</url>
  <url type="help">https://github.com/sniper1720/khushu/issues</url>
  <developer type="person" id="io.github.sniper1720">
    <name>Djalel Oukid</name>
  </developer>
  <categories>
    <category>Utility</category>
    <category>Education</category>
  </categories>
  <keywords>
    <keyword>prayer</keyword>
    <keyword>salah</keyword>
    <keyword>adhan</keyword>
    <keyword>adkar</keyword>
    <keyword>qibla</keyword>
    <keyword>muslim</keyword>
    <keyword>islam</keyword>
  </keywords>
  <branding>
    <color type="primary" scheme_preference="light">#3584e4</color>
    <color type="primary" scheme_preference="dark">#1a5fb4</color>
  </branding>
  <content_rating type="oars-1.1" />
  <releases>
    <release version="1.0.0" date="2026-02-24" />
  </releases>
  <requires>
    <display_length compare="ge">360</display_length>
  </requires>
  <recommends>
    <control>touch</control>
  </recommends>
  <custom>
    <value key="Purism::form_factor">mobile</value>
  </custom>
</component>
