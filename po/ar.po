#: data/io.github.sniper1720.khushu.desktop.in:3
#: data/appdata/io.github.sniper1720.khushu.metainfo.xml.in:7 src/main.rs:383
msgid "An all-in-one Muslim app for Linux"
msgstr "تطبيق إسلامي شامل لنظام لينكس"

#: data/io.github.sniper1720.khushu.desktop.in:9
msgid "Prayer;Islam;Salah;"
msgstr "صلاة;إسلام;أذان;أذكار;قرآن;"

#: data/appdata/io.github.sniper1720.khushu.metainfo.xml.in:9
msgid ""
"Khushu is your all-in-one Muslim app for Linux desktop, tablets, and "
"smartphones. It centralizes your daily worship by providing accurate prayer "
"times, native staggered Adkar notifications, and a dedicated Noble Quran "
"reader—all with uncompromising privacy and zero telemetry."
msgstr ""
"تطبيق خشوع هو تطبيق إسلامي شامل لنظام لينكس، والأجهزة اللوحية، والهواتف "
"الذكية. يوحّد عباداتك اليومية من خلال توفير أوقات صلاة دقيقة، وتنبيهات "
"أذكار متتالية، وقارئ مخصص للقرآن الكريم — كل ذلك مع خصوصية تامة وبدون أي "
"تتبع."

#: data/appdata/io.github.sniper1720.khushu.metainfo.xml.in:16
msgid "Accurate prayer calculation methods (Offline)"
msgstr "طرق حساب دقيقة لأوقات الصلاة (بدون إنترنت)"

#: data/appdata/io.github.sniper1720.khushu.metainfo.xml.in:17
msgid "Morning, Evening, and Night Adkar with built-in counters"
msgstr "أذكار الصباح والمساء والنوم مع عدادات مدمجة"

#: data/appdata/io.github.sniper1720.khushu.metainfo.xml.in:18
msgid "Customizable Adhan system notifications (Makkah/Madinah audio)"
msgstr "تنبيهات أذان قابلة للتخصيص (صوت مكة/المدينة)"

#: data/appdata/io.github.sniper1720.khushu.metainfo.xml.in:19
msgid ""
"Dedicated Noble Quran reader with adjustable Arabic and translation "
"typography"
msgstr ""
"قارئ قرآن كريم مخصص مع إمكانية تخصيص خطوط العربية والترجمة"

#: data/appdata/io.github.sniper1720.khushu.metainfo.xml.in:20
msgid "Interactive Qibla compass"
msgstr "بوصلة قبلة تفاعلية"

#: data/appdata/io.github.sniper1720.khushu.metainfo.xml.in:21
msgid "Hijri calendar mapping"
msgstr "مطابقة دقيقة للتقويم الهجري"

#: data/appdata/io.github.sniper1720.khushu.metainfo.xml.in:22
msgid "Privacy-first local encryption for your location data"
msgstr "تشفير محلي لبيانات الموقع مع أولوية الخصوصية"

#: data/appdata/io.github.sniper1720.khushu.metainfo.xml.in:23
msgid "Modern Libadwaita interface with adaptive Dark Mode"
msgstr "واجهة Libadwaita حديثة مع وضع داكن متكيّف"

#: data/appdata/io.github.sniper1720.khushu.metainfo.xml.in:24
msgid "Multi-language support"
msgstr "دعم تعدد اللغات"

#: data/appdata/io.github.sniper1720.khushu.metainfo.xml.in:30
msgid ""
"Welcome & Onboarding: Easy first-time setup for location, language, and "
"calculation method"
msgstr ""
"الترحيب والإعداد: إعداد سهل للمرة الأولى للموقع واللغة وطريقة الحساب"

#: data/appdata/io.github.sniper1720.khushu.metainfo.xml.in:34
msgid ""
"Prayer Times Dashboard: View accurate daily Salah times, upcoming prayer "
"countdown, and Hijri date"
msgstr ""
"لوحة أوقات الصلاة: عرض أوقات الصلاة اليومية الدقيقة، والعد التنازلي "
"للصلاة القادمة، والتاريخ الهجري"

#: data/appdata/io.github.sniper1720.khushu.metainfo.xml.in:38
msgid ""
"Hijri Calendar: Browse the full Islamic calendar with accurate Hijri date "
"mapping"
msgstr ""
"التقويم الهجري: استعرض التقويم الإسلامي الكامل مع مطابقة دقيقة للتاريخ "
"الهجري"

#: data/appdata/io.github.sniper1720.khushu.metainfo.xml.in:42
msgid ""
"Interactive Qibla compass pointing to Mecca via GPS or E-Compass sensor"
msgstr ""
"بوصلة قبلة تفاعلية تشير إلى مكة عبر GPS أو حساس البوصلة"

#: data/appdata/io.github.sniper1720.khushu.metainfo.xml.in:46
msgid ""
"Noble Quran: Read Arabic ayat and translations with adjustable typography"
msgstr ""
"القرآن الكريم: اقرأ الآيات العربية والترجمات مع إمكانية ضبط الخط"

#: data/appdata/io.github.sniper1720.khushu.metainfo.xml.in:50
msgid ""
"Adkar & Supplications: Access Daily Adkar with built-in counters and "
"staggered notifications"
msgstr ""
"الأذكار والأدعية: أذكار يومية مع عدادات مدمجة وإشعارات متتالية"

#: data/appdata/io.github.sniper1720.khushu.metainfo.xml.in:54
msgid ""
"App Settings: Configure your location, language, appearance, and prayer "
"settings"
msgstr ""
"إعدادات التطبيق: اضبط موقعك ولغتك ومظهرك وإعدادات الصلاة"

#: data/appdata/io.github.sniper1720.khushu.metainfo.xml.in:63
msgid "Djalel Oukid"
msgstr "جلال وكيد"

#: data/appdata/io.github.sniper1720.khushu.metainfo.xml.in:70
msgid "prayer"
msgstr "صلاة"

#: data/appdata/io.github.sniper1720.khushu.metainfo.xml.in:71
msgid "salah"
msgstr "صلاة"

#: data/appdata/io.github.sniper1720.khushu.metainfo.xml.in:72
msgid "adhan"
msgstr "أذان"

#: data/appdata/io.github.sniper1720.khushu.metainfo.xml.in:73
msgid "adkar"
msgstr "أذكار"

#: data/appdata/io.github.sniper1720.khushu.metainfo.xml.in:74
msgid "quran"
msgstr "قرآن"

#: data/appdata/io.github.sniper1720.khushu.metainfo.xml.in:75
msgid "qibla"
msgstr "قبلة"

#: data/appdata/io.github.sniper1720.khushu.metainfo.xml.in:76
msgid "muslim"
msgstr "مسلم"

#: data/appdata/io.github.sniper1720.khushu.metainfo.xml.in:77
msgid "islam"
msgstr "إسلام"

#: data/appdata/io.github.sniper1720.khushu.metainfo.xml.in:88
msgid ""
"Added a fully offline Noble Qur'an module featuring the Qur'anic text in "
"Uthmanic orthography (rasm), translations, mushaf-style navigation, "
"diacritic-aware search, saved reading positions, and adjustable typography."
msgstr ""
"إضافة وحدة متكاملة للمصحف الشريف تعمل دون اتصال بالإنترنت، تتضمن النص "
"القرآني بالرسم العثماني، وترجمات، وتصفحًا بأسلوب المصحف، وبحثًا يراعي "
"التشكيل، مع حفظ مواضع القراءة وإمكانية ضبط الخط."

#: data/appdata/io.github.sniper1720.khushu.metainfo.xml.in:89
msgid "Added Mawaqit API integration as an alternative prayer times source."
msgstr ""
"إضافة تكامل مع Mawaqit API كمصدر بديل لمواقيت الصلاة."

#: data/appdata/io.github.sniper1720.khushu.metainfo.xml.in:90
msgid ""
"Added ICU-backed localization for location and timezone labels, plus "
"validated custom IANA timezone editing."
msgstr ""
"إضافة دعم ICU لتوطين تسميات الموقع والمنطقة الزمنية، مع التحقق من صحة "
"تعديل مناطق IANA الزمنية المخصصة."

#: data/appdata/io.github.sniper1720.khushu.metainfo.xml.in:91
msgid ""
"Reorganized settings into clearer General, Prayer Setup, and Alerts sections "
"with improved inline editing behavior."
msgstr ""
"إعادة تنظيم الإعدادات إلى أقسام أوضح: عام، إعدادات الصلاة، والتنبيهات، مع "
"تحسين أسلوب التحرير المباشر."

#: data/appdata/io.github.sniper1720.khushu.metainfo.xml.in:92
msgid ""
"Fixed Snap tray icon visibility via an upstream patch to ksni (resolves "
"AppArmor D-Bus blocking)."
msgstr ""
"إصلاح ظهور أيقونة شريط Snap عبر تصحيح في المصدر (upstream) لمكتبة ksni "
"(يحل مشكلة حظر D-Bus بواسطة AppArmor)."

#: data/appdata/io.github.sniper1720.khushu.metainfo.xml.in:99
msgid "Fixed Snap autostart and notification icon rendering."
msgstr "إصلاح التشغيل التلقائي وعرض أيقونة الإشعارات في Snap."

#: data/appdata/io.github.sniper1720.khushu.metainfo.xml.in:100
msgid "Improved locale detection and fallback logic."
msgstr "تحسين اكتشاف اللغة ومنطق الرجوع للافتراضي."

#: data/appdata/io.github.sniper1720.khushu.metainfo.xml.in:107
msgid "Fixed Flatpak autostart failure and missing --background flag."
msgstr ""
"إصلاح فشل التشغيل التلقائي في Flatpak وإضافة علامة --background المفقودة."

#: data/appdata/io.github.sniper1720.khushu.metainfo.xml.in:108
msgid ""
"Fixed over-translation of proper nouns (e.g., Muslim) in non-English locales."
msgstr ""
"إصلاح الترجمة الزائدة لأسماء الأعلام (مثل: Muslim) في اللغات غير الإنجليزية."

#: data/appdata/io.github.sniper1720.khushu.metainfo.xml.in:109
msgid "Added new localized AppStream screenshots for improved store presence."
msgstr ""
"إضافة لقطات شاشة مترجمة جديدة لتحسين ظهور التطبيق في المتاجر."

#: data/appdata/io.github.sniper1720.khushu.metainfo.xml.in:116
msgid "Fixed tray icon translation extraction (Quit and Open Khushu entries)."
msgstr ""
"إصلاح استخراج ترجمة أيقونة شريط المهام (إدخالات الخروج وفتح خشوع)."

#: data/appdata/io.github.sniper1720.khushu.metainfo.xml.in:117
msgid "Fixed AppStream metadata translation (descriptions and keywords)."
msgstr ""
"إصلاح ترجمة بيانات AppStream الوصفية (الأوصاف والكلمات المفتاحية)."

#: data/appdata/io.github.sniper1720.khushu.metainfo.xml.in:118
msgid "Improved tray behavior to update labels immediately on language change."
msgstr ""
"تحسين سلوك شريط المهام لتحديث التسميات فورًا عند تغيير اللغة."

#: data/appdata/io.github.sniper1720.khushu.metainfo.xml.in:125
msgid "Initial stable release of Khushu."
msgstr "الإصدار المستقر الأول لتطبيق خشوع."


