#: data/io.github.sniper1720.khushu.desktop.in:3 data/appdata/io.github.sniper1720.khushu.metainfo.xml.in:7 src/main.rs:383
msgid "An all-in-one Muslim app for Linux"
msgstr "Aplikasi serba guna untuk umat Muslim di Linux"

#: data/io.github.sniper1720.khushu.desktop.in:9
msgid "Prayer;Islam;Salah;"
msgstr "Doa;Islam;Shalat;"

#: data/appdata/io.github.sniper1720.khushu.metainfo.xml.in:9
msgid ""
"Khushu is your all-in-one Muslim app for Linux desktop, tablets, and smartphones. It centralizes your daily worship by providing accurate prayer times, native staggered Adkar notifications, and a dedicated Noble Quran reader—all with uncompromising privacy and zero "
"telemetry."
msgstr ""
"Khushu adalah aplikasi serba guna untuk umat Muslim yang dirancang khusus untuk desktop Linux, tablet, dan ponsel. Aplikasi ini memudahkan ibadah harian Anda dengan menyediakan waktu shalat yang akurat, notifikasi Al-Ma'surat yang terintegrasi secara otomatis, "
"serta pembaca Al-Quran yang khusus—semuanya dengan privasi yang terjamin dan tanpa pengumpulan data."

#: data/appdata/io.github.sniper1720.khushu.metainfo.xml.in:16
msgid "Accurate prayer calculation methods (Offline)"
msgstr "Metode perhitungan shalat yang akurat (Offline)"

#: data/appdata/io.github.sniper1720.khushu.metainfo.xml.in:17
msgid "Morning, Evening, and Night Adkar with built-in counters"
msgstr "Al-Ma'surat Pagi, Sore, dan Malam dengan penghitung bawaan"

#: data/appdata/io.github.sniper1720.khushu.metainfo.xml.in:18
msgid "Customizable Adhan system notifications (Makkah/Madinah audio)"
msgstr "Pemberitahuan sistem adzan yang dapat disesuaikan (audio Makkah/Madinah)"

#: data/appdata/io.github.sniper1720.khushu.metainfo.xml.in:19
msgid "Dedicated Noble Quran reader with adjustable Arabic and translation typography"
msgstr "Aplikasi pembaca Al-Quran yang dilengkapi dengan pilihan tipografi teks Arab dan terjemahan yang dapat disesuaikan"

#: data/appdata/io.github.sniper1720.khushu.metainfo.xml.in:20
msgid "Interactive Qibla compass"
msgstr "Kompas arah Kiblat interaktif"

#: data/appdata/io.github.sniper1720.khushu.metainfo.xml.in:21
msgid "Hijri calendar mapping"
msgstr "Pemetaan kalender Hijriah"

#: data/appdata/io.github.sniper1720.khushu.metainfo.xml.in:22
msgid "Privacy-first local encryption for your location data"
msgstr "Enkripsi lokal yang mengutamakan privasi untuk data lokasi Anda"

#: data/appdata/io.github.sniper1720.khushu.metainfo.xml.in:23
msgid "Modern Libadwaita interface with adaptive Dark Mode"
msgstr "Antarmuka Libadwaita modern dengan Mode Gelap yang adaptif"

#: data/appdata/io.github.sniper1720.khushu.metainfo.xml.in:24
msgid "Multi-language support"
msgstr "Dukungan multibahasa"

#: data/appdata/io.github.sniper1720.khushu.metainfo.xml.in:30
msgid "Welcome & Onboarding: Easy first-time setup for location, language, and calculation method"
msgstr "Selamat Datang & Panduan Awal: Pengaturan awal yang mudah untuk lokasi, bahasa, dan metode perhitungan"

#: data/appdata/io.github.sniper1720.khushu.metainfo.xml.in:34
msgid "Prayer Times Dashboard: View accurate daily Salah times, upcoming prayer countdown, and Hijri date"
msgstr "Dasbor Waktu Shalat: Lihat jadwal shalat harian yang akurat, hitung mundur waktu shalat berikutnya, dan tanggal Hijriah"

#: data/appdata/io.github.sniper1720.khushu.metainfo.xml.in:38
msgid "Hijri Calendar: Browse the full Islamic calendar with accurate Hijri date mapping"
msgstr "Kalender Hijriah: Lihat kalender Islam lengkap dengan pemetaan tanggal Hijriah yang akurat"

#: data/appdata/io.github.sniper1720.khushu.metainfo.xml.in:42
msgid "Interactive Qibla compass pointing to Mecca via GPS or E-Compass sensor"
msgstr "Kompas Kiblat interaktif yang menunjuk ke arah Mekah melalui GPS atau sensor E-Compass"

#: data/appdata/io.github.sniper1720.khushu.metainfo.xml.in:46
msgid "Noble Quran: Read Arabic ayat and translations with adjustable typography"
msgstr "Al-Quran yang Mulia: Baca ayat-ayat dalam bahasa Arab beserta terjemahannya dengan tata letak teks yang dapat disesuaikan"

#: data/appdata/io.github.sniper1720.khushu.metainfo.xml.in:54
msgid "App Settings: Configure your location, language, appearance, and prayer settings"
msgstr "Pengaturan Aplikasi: Atur lokasi, bahasa, tampilan, dan pengaturan doa Anda"

#: data/appdata/io.github.sniper1720.khushu.metainfo.xml.in:50
msgid "Adkar & Supplications: Access Daily Adkar with built-in counters and staggered notifications"
msgstr "Al - Ma'surat dan Permohonan: Akses Al-Ma'surat harian dengan penghitung bawaan dan notifikasi bertahap"

#: data/appdata/io.github.sniper1720.khushu.metainfo.xml.in:63
msgid "Djalel Oukid"
msgstr "Djalel Oukid"

